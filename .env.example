# --- DSA Data Studio Environment Configuration ---
# Copy this file to '.env' and fill in your values.

# Which provider to use? Options: 'openai', 'anthropic', 'gemini'
LLM_PROVIDER=openai

# --- OpenAI Configuration ---
OPENAI_API_KEY=your-openai-api-key-here
# Popular models: gpt-4o, gpt-4o-mini, o3-mini, o1-mini
OPENAI_MODEL=o3-mini
# Set to 'false' if using o1-mini, o1-preview, or o3-mini as they often reject temperature parameters
OPENAI_SUPPORTS_TEMPERATURE=false

# --- Anthropic Configuration ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Popular models: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.2

# --- Gemini Configuration (Placeholder) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro
